{
  "name": "rust-riders",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npm run build && webpack serve --mode development",
    "build": "npm run lint && npm run format && npm run docs && npm run typecheck && webpack --mode production",
    "typecheck": "tsc",
    "lint": "oxlint --fix src",
    "lint:fix": "oxlint --fix --fix-suggestions src",
    "docs": "markdownlint-cli2 --fix \"**/*.md\" \"!node_modules\"",
    "format": "prettier --write \"src/**/*.{cjs,mjs,js,jsx,ts,tsx,mts,cts,json,html,css}\"",
    "update": "ncu -u --peer"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/cli": "8.x",
    "@babel/core": "8.x",
    "@babel/preset-env": "8.x",
    "@babel/preset-react": "8.x",
    "@babel/preset-typescript": "8.x",
    "@types/lodash": "4.x",
    "@types/picomatch": "^4.0.3",
    "@types/react": "19.x",
    "@types/react-dom": "19.x",
    "babel-loader": "10.x",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "7.x",
    "html-webpack-plugin": "5.x",
    "markdownlint-cli2": "0.23.x",
    "npm-check-updates": "22.x",
    "oxlint": "1.x",
    "oxlint-tsgolint": "0.24.x",
    "prettier": "3.x",
    "style-loader": "4.x",
    "typescript": "7.x",
    "webpack": "5.x",
    "webpack-cli": "7.x",
    "webpack-dev-server": "6.x"
  },
  "dependencies": {
    "react": "19.x",
    "react-dom": "19.x",
    "react-router-dom": "7.x"
  }
}
